{
  "expo": {
    "name": "LiftX",
    "slug": "liftx-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.liftx.mobile"
    },
    "android": {
      "package": "com.liftx.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0F"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      [
        "expo-camera",
        { "cameraPermission": "LiftX uses your camera to scan gym QR codes." }
      ],
      [
        "expo-image-picker",
        { "photosPermission": "LiftX uses your photos to track your fitness progress." }
      ],
      "expo-secure-store"
    ],
    "scheme": "liftx"
  }
}
